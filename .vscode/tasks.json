{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev server",
      "type": "shell",
      "command": "npm run dev -- --host",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "ready in \\d+.*ms"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "kill dev server",
      "type": "shell",
      "command": "pkill -f 'node_modules/.bin/vite' || true",
      "presentation": {
        "reveal": "never",
        "panel": "dedicated"
      }
    }
  ]
}
